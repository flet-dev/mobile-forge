+def prefix_ambiguous_ios(val: str):
+    cnames = ["Rect", "Point", "Size"]
+    r = val
+    if val in cnames or val.startswith("Ptr<"):
+        r = f"cv::{r}"
+    for cn in cnames:
+        r = r.replace(f"<{cn}>", f"<cv::{cn}>")
+        if r.startswith(f"{cn}("):
+            r = f"cv::{r}"
+    # also qualify any bare Ptr< nested inside other templates
+    # (e.g. std::vector<Ptr<CChecker>>) which the leading check above misses
+    r = re.sub(r"(?<![:\w])Ptr<", "cv::Ptr<", r)
+    return r
 
