+        # is the app-relative path to the framework binary. ctypes.CDLL needs the
+        # binary, not the marker; resolve it exactly as CPython's
+        # AppleFrameworkLoader does (join the marker text above the wheel dir).
+        try:
+            rel = marker.read_text().strip()
