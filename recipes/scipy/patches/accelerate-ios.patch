# scipy's Accelerate gate (scipy/meson.build) only computes `macOS13_3_or_later`
# when host_machine.system() == 'darwin', then errors out for blas=accelerate
# otherwise. forge's iOS cross-file sets system='iphoneos'/'iphonesimulator', so
# the gate stays false and the build aborts. The Accelerate framework is the same
# on iOS, and its modern (macOS-13.3-equivalent) LAPACK is available from iOS 16.4
# onward — well below the active iOS SDK — so enable the new-Accelerate path for
# iOS systems too. Only affects iOS (Android uses blas=openblas).
--- a/scipy/meson.build
+++ b/scipy/meson.build
@@ -268,6 +268,10 @@
   r = run_command('xcrun', '-sdk', 'macosx', '--show-sdk-version', check: true)
   sdkVersion = r.stdout().strip()
   macOS13_3_or_later = sdkVersion.version_compare('>=13.3')
+elif host_machine.system() in ['ios', 'iphoneos', 'iphonesimulator']
+  # iOS Accelerate provides the modern (macOS 13.3-equivalent) LAPACK from
+  # iOS 16.4 onward; the active iOS SDK is well past that, so enable it.
+  macOS13_3_or_later = true
 endif
 
 _args_blas_lp64 = []
