+                if os.path.isdir(os.path.join(_root, _pkg)):
+                    return _root
+        except Exception:
+            pass
+        for _d in sys.path:
+            if _d and os.path.isdir(os.path.join(_d, _pkg)):
+                return _d
+        return None
